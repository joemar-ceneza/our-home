# Base URL of the backend API (must include the /api path segment)
REACT_APP_API_URL=http://localhost:5000/api

# Stripe publishable key — safe to expose to the browser (pk_, not sk_)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_xxx

# NOTE: every REACT_APP_* variable is inlined into the built JS bundle and is
# publicly visible. Never put a secret (API token, sk_ key, DB password) here.
